{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "[ -x .agent/scripts/hooks/session-start.sh ] && bash .agent/scripts/hooks/session-start.sh || jq -cn --arg msg '[git-dev] missing .agent/scripts/hooks/session-start.sh — run bootstrap-agent-project . --type git-dev' '{systemMessage:$msg}'",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "[ -x .agent/scripts/hooks/post-edit.sh ] && bash .agent/scripts/hooks/post-edit.sh || true",
            "type": "command"
          }
        ],
        "matcher": "apply_patch|exec_command"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "[ -x .agent/scripts/hooks/session-stop.sh ] && bash .agent/scripts/hooks/session-stop.sh || true",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  }
}
